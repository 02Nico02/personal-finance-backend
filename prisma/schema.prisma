generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ImportBatch {
  id              String   @id @default(uuid())
  fileName        String?
  originalFileName String?
  checksum        String?
  status          String   @default("created")
  detectedTables  Json?
  warnings        Json?
  errors          Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  importedRows    ImportedRow[]
  instruments     Instrument[]
  classifications InstrumentClassification[]
  operations      InvestmentOperation[]
  sales           InvestmentSale[]
  movements       InvestmentMovement[]
  prices          PriceHistory[]
  benchmarks      BenchmarkIndex[]
  pendingOrders   PendingOrder[]
  positions       CurrentPositionSnapshot[]
}

model ImportedRow {
  id              String   @id @default(uuid())
  importBatchId   String
  sourceTable     String
  sourceSheet     String   @default("workbook")
  sourceRowId     String
  rawData         Json?
  normalizedData  Json?
  rowHash         String?
  status          String   @default("imported")
  warnings        Json?
  errors          Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  importBatch     ImportBatch @relation(fields: [importBatchId], references: [id])
  instruments     Instrument[]
  classifications InstrumentClassification[]
  operations      InvestmentOperation[]
  sales           InvestmentSale[]
  movements       InvestmentMovement[]
  prices          PriceHistory[]
  benchmarks      BenchmarkIndex[]
  pendingOrders   PendingOrder[]
  positions       CurrentPositionSnapshot[]

  @@unique([importBatchId, sourceTable, sourceSheet, sourceRowId])
  @@index([importBatchId, sourceTable, sourceSheet, sourceRowId])
}

model Instrument {
  id              String   @id @default(uuid())
  symbol          String
  name            String?
  currency        String   @default("UNKNOWN")
  instrumentType  String   @default("UNKNOWN")
  isFci           Boolean  @default(false)
  active          Boolean  @default(true)
  importBatchId   String?
  importedRowId   String?
  sourceTable     String?
  sourceSheet     String?
  sourceRowId     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  importBatch     ImportBatch? @relation(fields: [importBatchId], references: [id])
  importedRow     ImportedRow? @relation(fields: [importedRowId], references: [id])
  classifications InstrumentClassification[]
  operations      InvestmentOperation[]
  sales           InvestmentSale[]
  movements       InvestmentMovement[]
  prices          PriceHistory[]
  pendingOrders   PendingOrder[]
  positions       CurrentPositionSnapshot[]

  @@unique([symbol, currency, instrumentType])
  @@index([symbol])
  @@index([importBatchId, sourceTable, sourceRowId])
}

model InstrumentClassification {
  id            String    @id @default(uuid())
  instrumentId  String
  importBatchId String
  importedRowId String?
  sourceTable   String
  sourceSheet   String?
  sourceRowId   String
  type          String?
  sector        String?
  subsector     String?
  region        String?
  expectedValue Decimal?  @db.Decimal(18, 6)
  currentValue  Decimal?  @db.Decimal(18, 6)
  amount        Decimal?  @db.Decimal(18, 6)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  instrument    Instrument  @relation(fields: [instrumentId], references: [id])
  importBatch   ImportBatch  @relation(fields: [importBatchId], references: [id])
  importedRow   ImportedRow? @relation(fields: [importedRowId], references: [id])

  @@index([instrumentId])
  @@index([importBatchId, sourceTable, sourceRowId])
}

model InvestmentOperation {
  id             String    @id @default(uuid())
  instrumentId   String
  importBatchId  String
  importedRowId  String?
  sourceTable    String
  sourceSheet    String?
  sourceRowId    String
  operationDate  DateTime?
  currency       String?
  quantity       Decimal?  @db.Decimal(18, 6)
  buyPrice       Decimal?  @db.Decimal(18, 6)
  totalCost      Decimal?  @db.Decimal(18, 6)
  currentPrice   Decimal?  @db.Decimal(18, 6)
  currentValue   Decimal?  @db.Decimal(18, 6)
  variationAmount Decimal? @db.Decimal(18, 6)
  variationPercent Decimal? @db.Decimal(18, 6)
  monthlyRate    Decimal?  @db.Decimal(18, 6)
  annualRate     Decimal?  @db.Decimal(18, 6)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  instrument     Instrument   @relation(fields: [instrumentId], references: [id])
  importBatch    ImportBatch   @relation(fields: [importBatchId], references: [id])
  importedRow    ImportedRow?  @relation(fields: [importedRowId], references: [id])

  @@index([instrumentId, operationDate])
  @@index([importBatchId, sourceTable, sourceRowId])
}

model InvestmentSale {
  id             String    @id @default(uuid())
  instrumentId   String
  importBatchId  String
  importedRowId  String?
  sourceTable    String
  sourceSheet    String?
  sourceRowId    String
  buyDate        DateTime?
  sellDate       DateTime?
  currency       String?
  quantity       Decimal?  @db.Decimal(18, 6)
  buyPrice       Decimal?  @db.Decimal(18, 6)
  sellPrice      Decimal?  @db.Decimal(18, 6)
  originalCost   Decimal?  @db.Decimal(18, 6)
  sellValue      Decimal?  @db.Decimal(18, 6)
  realizedGain   Decimal?  @db.Decimal(18, 6)
  variationAmount Decimal? @db.Decimal(18, 6)
  variationPercent Decimal? @db.Decimal(18, 6)
  minimumObjective Decimal? @db.Decimal(18, 6)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  instrument     Instrument   @relation(fields: [instrumentId], references: [id])
  importBatch    ImportBatch   @relation(fields: [importBatchId], references: [id])
  importedRow    ImportedRow?  @relation(fields: [importedRowId], references: [id])

  @@index([instrumentId, sellDate])
  @@index([importBatchId, sourceTable, sourceRowId])
}

model InvestmentMovement {
  id               String    @id @default(uuid())
  instrumentId     String
  importBatchId    String
  importedRowId    String?
  sourceTable      String
  sourceSheet      String?
  sourceRowId      String
  movementDate     DateTime?
  movementType     String?
  currency         String?
  amount           Decimal?  @db.Decimal(18, 6)
  affectsPerformance Boolean  @default(false)
  affectsInvestedCapital Boolean @default(false)
  capitalEffect    String?   @default("unknown")
  note             String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  instrument       Instrument   @relation(fields: [instrumentId], references: [id])
  importBatch      ImportBatch   @relation(fields: [importBatchId], references: [id])
  importedRow      ImportedRow?  @relation(fields: [importedRowId], references: [id])

  @@index([instrumentId, movementDate])
  @@index([importBatchId, sourceTable, sourceRowId])
}

model PriceHistory {
  id             String    @id @default(uuid())
  instrumentId   String
  importBatchId  String
  importedRowId  String?
  sourceTable    String
  sourceSheet    String?
  sourceRowId    String
  priceDate      DateTime?
  month          String?
  price          Decimal?  @db.Decimal(18, 6)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  instrument     Instrument   @relation(fields: [instrumentId], references: [id])
  importBatch    ImportBatch   @relation(fields: [importBatchId], references: [id])
  importedRow    ImportedRow?  @relation(fields: [importedRowId], references: [id])

  @@index([instrumentId, priceDate])
  @@index([importBatchId, sourceTable, sourceRowId])
}

model BenchmarkIndex {
  id                     String    @id @default(uuid())
  importBatchId          String
  importedRowId          String?
  sourceTable            String
  sourceSheet            String?
  sourceRowId            String
  benchmarkType          String    @default("unknown")
  benchmarkDate          DateTime?
  month                  String?
  tna                    Decimal?  @db.Decimal(18, 6)
  dailyReturnPercent     Decimal?  @db.Decimal(18, 6)
  indexValue             Decimal?  @db.Decimal(18, 6)
  inflationMonthlyPercent Decimal? @db.Decimal(18, 6)
  daysInMonth            Int?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  importBatch            ImportBatch  @relation(fields: [importBatchId], references: [id])
  importedRow            ImportedRow? @relation(fields: [importedRowId], references: [id])

  @@index([benchmarkType, benchmarkDate])
  @@index([importBatchId, sourceTable, sourceRowId])
}

model PendingOrder {
  id             String    @id @default(uuid())
  instrumentId   String
  importBatchId  String
  importedRowId  String?
  sourceTable    String
  sourceSheet    String?
  sourceRowId    String
  currency       String?
  quantity       Decimal?  @db.Decimal(18, 6)
  limitPrice     Decimal?  @db.Decimal(18, 6)
  reservedAmount Decimal?  @db.Decimal(18, 6)
  orderStatus    String    @default("pending")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  instrument     Instrument   @relation(fields: [instrumentId], references: [id])
  importBatch    ImportBatch   @relation(fields: [importBatchId], references: [id])
  importedRow    ImportedRow?  @relation(fields: [importedRowId], references: [id])

  @@index([instrumentId, orderStatus])
  @@index([importBatchId, sourceTable, sourceRowId])
}

model CurrentPositionSnapshot {
  id             String    @id @default(uuid())
  instrumentId   String
  importBatchId  String
  importedRowId  String?
  sourceTable    String
  sourceSheet    String?
  sourceRowId    String
  snapshotDate   DateTime?
  currency       String?
  positionType   String?
  quantity       Decimal?  @db.Decimal(18, 6)
  totalInvested  Decimal?  @db.Decimal(18, 6)
  currentPrice   Decimal?  @db.Decimal(18, 6)
  currentValue   Decimal?  @db.Decimal(18, 6)
  resultAmount   Decimal?  @db.Decimal(18, 6)
  resultPercent  Decimal?  @db.Decimal(18, 6)
  averagePrice   Decimal?  @db.Decimal(18, 6)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  instrument     Instrument   @relation(fields: [instrumentId], references: [id])
  importBatch    ImportBatch   @relation(fields: [importBatchId], references: [id])
  importedRow    ImportedRow?  @relation(fields: [importedRowId], references: [id])

  @@index([snapshotDate, instrumentId])
  @@index([importBatchId, sourceTable, sourceRowId])
}
