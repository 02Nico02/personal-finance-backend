generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ImportBatch {
  id        String   @id @default(uuid())
  fileName  String?
  status    String   @default("created")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
